## QuakeJS Reverse Proxy Configuration for SWAG
## 
## Purpose: Provides SSL termination for QuakeJS HTTP interface and WebSocket game traffic
## 
## Prerequisites:
## 1. SWAG container running with valid SSL certificates
## 2. quakejs-rootless container on same Docker network as SWAG
## 3. DNS configured for your domain pointing to your server
##
## Setup Instructions:
## 1. Copy this file to: /config/nginx/site-confs/quakejs.conf (in SWAG container)
## 2. Replace 'example.com' with your domain (e.g., quake.yourdomain.com or yourdomain.com)
## 3. Verify 'quakejs' matches your container name (or update to match)
## 4. Verify that SWAG and quakejs-rootless are on the same Docker network
## 5. Restart SWAG container: docker restart swag
##
## Architecture: Internet → SWAG (443) → quakejs-rootless (8080)
## Ports only required to be published on SWAG container
## Documentation: https://docs.linuxserver.io/general/swag/

# Unified Web and WebSocket interface on port 443
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name example.com;
    include /config/nginx/ssl.conf;
    client_max_body_size 0;
    location / {
        include /config/nginx/proxy.conf;
        include /config/nginx/resolver.conf;
        set $upstream_app quakejs;
        set $upstream_port 8080;
        set $upstream_proto http;
        proxy_pass $upstream_proto://$upstream_app:$upstream_port;
        # Security headers
        add_header Content-Security-Policy "upgrade-insecure-requests" always;
    }
}
